---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export const prerender = true;

// 1. Generar una nueva ruta para cada colección de productos
export async function getStaticPaths() {
  const productos = await getCollection('productos');
  return productos.map(producto => ({
    params: { id: producto.id },
    props: { producto },
  }));
}

// 2. Para tu plantilla, puedes obtener el producto real
const { producto } = Astro.props;
const { Content } = await render(producto);

// Preparar mensaje de WhatsApp
const whatsappMessage = encodeURIComponent(`Hola, me interesa obtener una cotización para el producto: ${producto.data.titulo}`);
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '593000000000';
---

<Layout title={`${producto.data.titulo} - SakuraLab`}>
  <Header />
  
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:py-12 pt-24">
    <nav aria-label="Breadcrumb" class="flex text-sm text-on-surface-variant mb-8">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a class="hover:text-primary transition-colors" href="/">Inicio</a>
        </li>
        <li>
          <div class="flex items-center">
            <span class="material-symbols-outlined text-sm mx-1">chevron_right</span>
            <a class="hover:text-primary transition-colors" href="/#trabajos">Productos</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="material-symbols-outlined text-sm mx-1">chevron_right</span>
            <span class="text-on-surface font-medium">{producto.data.titulo}</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-2 lg:gap-12 xl:gap-16">
      <div class="mb-10 lg:mb-0">
        <div class="relative w-full aspect-square lg:aspect-auto lg:h-150 rounded-lg bg-surface-container-low overflow-hidden shadow-sm group">
          <Image 
            src={producto.data.imagen} 
            alt={producto.data.titulo} 
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <button class="absolute bottom-4 right-4 bg-surface/80 backdrop-blur rounded-full p-2 shadow-sm text-on-surface hover:bg-surface transition-colors">
            <span class="material-symbols-outlined">zoom_in</span>
          </button>
        </div>
      </div>

      <div class="flex flex-col">
        <div class="mb-6 border-b border-surface-variant pb-6">
          <div class="flex items-center gap-2 mb-2 text-secondary text-sm font-semibold tracking-wider uppercase">
            <span class="material-symbols-outlined text-base">architecture</span>
            <span>{producto.data.categoria || 'Producto'}</span>
          </div>
          <h1 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-bold text-on-surface leading-tight mb-4">
            {producto.data.titulo}
          </h1>
          <div class="flex flex-col gap-1">
            <span class="text-4xl font-headline font-bold text-primary">${producto.data.precio?.toFixed(2) || '25.00'}</span>
            <span class="text-sm text-on-surface-variant">Precio base (sujeto a dimensiones)</span>
          </div>
        </div>

        <div class="prose max-w-none mb-8 text-on-surface-variant">
          <p>{producto.data.descripcion || 'Diseñamos y fabricamos adornos personalizados...'}</p>
          <Content />
        </div>

        <div class="mb-8">
          <h3 class="font-headline font-semibold text-lg text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">straighten</span>
            Especificaciones Técnicas
          </h3>
          <ul class="space-y-3">
            <li class="flex gap-3 text-on-surface-variant bg-surface-container-low p-3 rounded-md">
              <span class="material-symbols-outlined text-secondary shrink-0">square_foot</span>
              <div>
                <span class="font-semibold text-on-surface">Material:</span> {producto.data.material || 'MDF de alta densidad'}
              </div>
            </li>
            <li class="flex gap-3 text-on-surface-variant bg-surface-container-low p-3 rounded-md">
              <span class="material-symbols-outlined text-secondary shrink-0">aspect_ratio</span>
              <div>
                <span class="font-semibold text-on-surface">Dimensiones:</span> {producto.data.dimensiones || 'Área de trabajo de 90cm x 60cm'}
              </div>
            </li>
            <li class="flex gap-3 text-on-surface-variant bg-surface-container-low p-3 rounded-md">
              <span class="material-symbols-outlined text-secondary shrink-0">precision_manufacturing</span>
              <div>
                <span class="font-semibold text-on-surface">Precisión:</span> Corte láser de +/- 0.1mm de tolerancia.
              </div>
            </li>
          </ul>
        </div>

        <div class="mt-auto pt-6 border-t border-surface-variant sticky bottom-0 bg-surface/90 backdrop-blur py-4 lg:static lg:py-0 z-40">
          <div class="flex flex-col sm:flex-row gap-4">
            <a class="flex-1 flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#128C7E] text-white font-headline font-semibold text-lg py-4 px-8 rounded-lg shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300" href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`} target="_blank">
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path>
              </svg>
              Cotizar Ahora / Hacer Pedido
            </a>
          </div>
        </div>
      </div>
    </div>

    
  </main>
  <Footer />
</Layout>