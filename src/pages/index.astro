---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

// Obtener los productos desde la colección
const productosData = await getCollection('productos');
const productosDestacados = productosData.filter(producto => producto.data.destacado);

// Imagen principal del Hero (esta se queda manual porque es estática de diseño)
import principalImg from '../assets/imgs/principal.jpeg';
---

<Layout title="Inicio - Sakura Lab">
	<Header />
	
	<main class="pt-24 pb-32 max-w-7xl mx-auto px-6">
		<section class="grid md:grid-cols-2 gap-12 items-center mb-24 min-h-716px">
			<div class="flex flex-col items-start gap-6 max-w-xl">
				<span class="text-primary font-label text-xs tracking-[0.2em] uppercase font-bold">Artesanía &amp; Tecnología</span>
				<h1 class="font-serif text-5xl md:text-7xl font-bold text-on-surface leading-[1.1] italic">
					Sakura Lab: detalles que florecen
				</h1>
				<p class="text-on-surface-variant text-lg leading-relaxed">
					Personalizamos tus momentos especiales con tecnología 3D, grabado láser de alta precisión y sublimación artesanal.
				</p>
				<a href="#galeria" class="group bg-primary text-on-primary px-8 py-4 rounded-xl font-bold flex items-center gap-3 hover:translate-y--4px transition-all shadow-lg active:scale-95">
					Diseñar algo único
					<span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" data-icon="arrow_forward">arrow_forward</span>
				</a>
			</div>
			<div class="relative">
				<div class="rounded-[2.5rem] overflow-hidden shadow-2xl">
					<Image alt="Lithophany lamp" class="w-full h-auto object-cover aspect-4/5 md:aspect-square" src={principalImg} />
				</div>
				<div class="absolute -bottom-6 -left-6 md:-left-12 bg-white/90 backdrop-blur-md p-6 rounded-2xl shadow-xl flex items-center gap-4 border border-white/50">
					<div class="bg-primary/10 p-3 rounded-full">
						<span class="material-symbols-outlined text-primary" data-icon="verified">verified</span>
					</div>
					<div>
						<span class="block text-[10px] uppercase tracking-widest text-secondary font-bold mb-1">Calidad Premium</span>
						<span class="block font-headline font-bold text-on-surface">Acabados de Lujo</span>
					</div>
				</div>
			</div>
		</section>

		<section class="mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-outline-variant/15 pb-12">
			<div class="max-w-2xl">
				<div class="flex items-center gap-2 mb-4">
					<span class="material-symbols-outlined text-primary text-sm" data-icon="straighten" data-weight="fill">straighten</span>
					<span class="font-label text-xs tracking-[0.2em] uppercase font-bold text-secondary">Vitalidad Técnica de Alta Precisión</span>
				</div>
				<h2 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter leading-tight text-on-surface">Creamos <span class="text-primary italic">detalles</span> que florecen</h2>
			</div>
			<div class="max-w-sm text-on-surface-variant font-light text-lg leading-relaxed">
				Transformamos conceptos técnicos en realidades tangibles mediante fabricación aditiva, corte láser y personalización de alta fidelidad.
			</div>
		</section>

		<div id="galeria" class="bento-grid scroll-mt-24">
			{productosDestacados.map((producto) => (
				<a href={`/productos/${producto.id}`} class={`${producto.data.claseCSS === 'especial-logo' ? '' : producto.data.claseCSS} group relative overflow-hidden bg-surface-container-low rounded-lg transition-all duration-500 block`}>
					<Image 
						class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
						src={producto.data.imagen} 
						alt={producto.data.titulo} 
					/>
					
					<div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-6 md:p-8">
						<span class="text-primary font-label text-[10px] tracking-[0.2em] uppercase mb-2 font-bold">
							{producto.data.categoria}
						</span>
						<h3 class={`font-headline font-bold text-white mb-4 ${producto.data.claseCSS === 'item-large' ? 'text-2xl' : 'text-xl'}`}>
							{producto.data.titulo}
						</h3>
						
						<button class="w-fit bg-white/20 backdrop-blur-md border border-white/30 text-white px-5 py-2 text-[10px] uppercase tracking-widest font-bold hover:bg-white hover:text-primary transition-all duration-300 flex items-center gap-2">
							Ver más
							<span class="material-symbols-outlined text-[14px]">arrow_forward</span>
						</button>
					</div>
				</a>
			))}
		</div>

		<div id="proceso" class="mt-16 lg:mt-24 border-t border-surface-variant pt-10 scroll-mt-24">
			<h2 class="font-headline text-2xl font-bold text-on-surface mb-6">Proceso de Diseño y Envío</h2>
			<!-- Componente del proceso -->
				<div class="grid sm:grid-cols-3 gap-8">
				<div class="bg-surface-container-low p-6 rounded-lg">
				<span class="material-symbols-outlined text-3xl text-primary mb-4 block">design_services</span>
				<h4 class="font-headline font-semibold text-lg text-on-surface mb-2">1. Envía tu Diseño</h4>
				<p class="text-on-surface-variant text-sm">Aceptamos formatos vectoriales (.ai, .svg, .dxf) o te ayudamos a crear el diseño desde cero.</p>
				</div>
				<div class="bg-surface-container-low p-6 rounded-lg">
				<span class="material-symbols-outlined text-3xl text-secondary mb-4 block">fact_check</span>
				<h4 class="font-headline font-semibold text-lg text-on-surface mb-2">2. Aprobación</h4>
				<p class="text-on-surface-variant text-sm">Te enviaremos un render o boceto técnico para tu aprobación antes de proceder al corte.</p>
				</div>
				<div class="bg-surface-container-low p-6 rounded-lg">
				<span class="material-symbols-outlined text-3xl text-primary mb-4 block">local_shipping</span>
				<h4 class="font-headline font-semibold text-lg text-on-surface mb-2">3. Fabricación y Envío</h4>
				<p class="text-on-surface-variant text-sm">Tiempo de producción estimado de 3-5 días hábiles. Envíos seguros a nivel nacional.</p>
				</div>
			</div>
		</div>	

		<section class="mt-32 bg-secondary-container rounded-sm p-8 md:p-16 flex flex-col md:flex-row items-center justify-between gap-10 overflow-hidden relative">
			<div class="relative z-10 text-center md:text-left">
				<h2 class="font-headline text-3xl md:text-5xl font-bold text-on-secondary-container mb-4 tracking-tighter">¿Tienes un proyecto en mente?</h2>
				<p class="text-on-secondary-container/80 text-lg max-w-md">Envíanos tus archivos o cuéntanos tu idea para recibir una cotización técnica personalizada.</p>
			</div>
			<button class="relative z-10 bg-primary text-on-primary px-10 py-5 font-bold uppercase tracking-widest text-sm flex items-center gap-4 hover:translate-y--1px transition-all shadow-xl active:scale-95">
				<span class="material-symbols-outlined" data-icon="chat" data-weight="fill">chat</span>
				Cotizar por WhatsApp
			</button>
			<span class="absolute -right-10 -bottom-10 material-symbols-outlined text-on-secondary-container/5 text-[240px] rotate-45 select-none" data-icon="straighten">straighten</span>
		</section>

		
	</main>

	<Footer />
</Layout>
