---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Sakura Lab" } = Astro.props;
---

<!doctype html>
<html lang="es" class="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO -->
		<meta name="description" content="Sakura Lab, dirigido por Angela Gonzalez. Especialistas en impresión 3D, tazas sublimadas y corte láser en Santa Elena, Ecuador. Realizamos envíos a todo el país." />
		<meta name="keywords" content="impresión 3D, tazas sublimadas, corte láser, Santa Elena, Ecuador, envíos a todo Ecuador, Sakura Lab, regalos personalizados, Angela Gonzalez" />
		<meta name="author" content="Angela Gonzalez" />
		<meta name="robots" content="index, follow" />
		
		<!-- Open Graph / Redes Sociales -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Especialistas en impresión 3D, tazas sublimadas y corte láser en Santa Elena, Ecuador. Envíos nacionales." />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="es_EC" />
		<meta property="og:image" content="/logo.png" />
		<meta property="og:url" content={Astro.url} />

		<!-- Google Fonts e iconos -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
		
		<title>{title}</title>
	</head>
	<body class="bg-surface font-body text-on-surface pattern-bg selection:bg-primary-fixed selection:text-on-primary-fixed">
		<slot />
	</body>
</html>
